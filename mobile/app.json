{
  "expo": {
    "name": "Atlas",
    "slug": "atlas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atlas.mobile"
    },
    "android": {
      "package": "com.atlas.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#030712"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "atlas"
  }
}
