{
  "expo": {
    "name": "Atlas",
    "slug": "atlas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "owner": "gillettdave",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atlas.mobile"
    },
    "android": {
      "package": "com.atlas.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#030712"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Atlas uses your location to find jobs near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "atlas",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de807da8-864a-4864-b389-88496455179e"
      }
    }
  }
}
