# Copy to .env and fill in real values.
# Do NOT commit .env — only this example file is in git.

# Runtime
ATLAS_ENV=production
ATLAS_LOG_LEVEL=INFO

# PostgreSQL (psycopg v3 driver)
ATLAS_DATABASE_URL=postgresql+psycopg://atlas:CHANGEME@localhost:5432/atlas

# API
ATLAS_API_HOST=0.0.0.0
ATLAS_API_PORT=8000

# Auth placeholder (not used in MVP; reserved for later)
ATLAS_ADMIN_TOKEN=CHANGEME

# --- LLM / AI features ---
ATLAS_OPENAI_API_KEY=sk-...
ATLAS_OPENAI_MODEL=gpt-4o-mini
ATLAS_PACKAGES_AI_ENABLED=true
ATLAS_CAREER_MEMORY_LLM_FACTS_DEFAULT=true
ATLAS_CAREER_MEMORY_LLM_FACTS_MAX_ITEMS=120

# --- Gmail IMAP (email intake) ---
ATLAS_GMAIL_IMAP_USERNAME=your-gmail@gmail.com
ATLAS_GMAIL_IMAP_PASSWORD=your-app-password
ATLAS_GMAIL_IMAP_HOST=imap.gmail.com
ATLAS_GMAIL_IMAP_PORT=993

# --- JSearch (RapidAPI) ---
ATLAS_JSEARCH_ENABLED=true
ATLAS_JSEARCH_API_KEY=YOUR_RAPIDAPI_KEY
ATLAS_JSEARCH_MAX_JOBS=200
ATLAS_JSEARCH_MAX_PAGES=2
ATLAS_JSEARCH_PAGE_GAP_SECONDS=0.8
ATLAS_JSEARCH_EMPLOYMENT_TYPES=FULLTIME,CONTRACTOR
ATLAS_JSEARCH_DATE_POSTED=week

# --- Adzuna ---
ATLAS_ADZUNA_ENABLED=true
ATLAS_ADZUNA_APP_ID=YOUR_APP_ID
ATLAS_ADZUNA_APP_KEY=YOUR_APP_KEY
ATLAS_ADZUNA_MAX_JOBS=200
ATLAS_ADZUNA_MAX_PAGES=3
ATLAS_ADZUNA_RESULTS_PER_PAGE=50
ATLAS_ADZUNA_PAGE_GAP_SECONDS=0.6
ATLAS_ADZUNA_MAX_DAYS_OLD=14
ATLAS_ADZUNA_COUNTRIES=us

# --- RemoteOK ---
ATLAS_REMOTEOK_ENABLED=true
ATLAS_REMOTEOK_TAGS=community,marketing,growth,content,social-media,seo,customer-success,customer-support,operations,product-management,partnerships,devrel,communications,brand
ATLAS_REMOTEOK_MAX_JOBS=300
ATLAS_REMOTEOK_MAX_AGE_DAYS=14

# --- We Work Remotely ---
ATLAS_WWR_ENABLED=true
ATLAS_WWR_CATEGORIES=marketing,customer-support,management-and-finance,all-other
ATLAS_WWR_MAX_JOBS=200
ATLAS_WWR_MAX_AGE_DAYS=14

# --- Arbeitnow ---
ATLAS_ARBEITNOW_ENABLED=true
ATLAS_ARBEITNOW_MAX_JOBS=200
ATLAS_ARBEITNOW_MAX_AGE_DAYS=14
ATLAS_ARBEITNOW_PAGE_GAP_SECONDS=0.5

# --- Himalayas ---
ATLAS_HIMALAYAS_ENABLED=true
ATLAS_HIMALAYAS_MAX_JOBS=300
ATLAS_HIMALAYAS_MAX_AGE_DAYS=14
ATLAS_HIMALAYAS_MAX_PAGES_PER_QUERY=5
ATLAS_HIMALAYAS_PAGE_GAP_SECONDS=0.5

# --- Jobicy ---
ATLAS_JOBICY_ENABLED=true
ATLAS_JOBICY_MAX_JOBS=200
ATLAS_JOBICY_MAX_AGE_DAYS=14
ATLAS_JOBICY_COUNT_PER_CALL=50

# --- Jobstash ---
ATLAS_JOBSTASH_ENABLED=true
ATLAS_JOBSTASH_PULL_PROFILE=incremental
ATLAS_JOBSTASH_API_BASE=https://middleware.jobstash.xyz
ATLAS_JOBSTASH_API_PAGE_SIZE=20
ATLAS_JOBSTASH_API_MAX_PAGES=25
ATLAS_JOBSTASH_SITEMAP_MAX_JOBS=500

# --- ATS board discovery (optional SerpAPI key) ---
# ATLAS_SERPAPI_KEY=

# --- The Muse ---
ATLAS_THEMUSE_ENABLED=true

# --- Scheduler ---
ATLAS_SCHEDULER_ENABLED=false
ATLAS_SCHEDULER_INTERVAL_SECONDS=60
ATLAS_SCHEDULER_MAX_PER_TICK=25

ATLAS_COLLECTOR_SCHEDULER_ENABLED=false
ATLAS_COLLECTOR_SCHEDULER_INTERVAL_SECONDS=120
ATLAS_COLLECTOR_SCHEDULER_MAX_PER_TICK=2

ATLAS_INTAKE_SCHEDULER_ENABLED=true
ATLAS_INTAKE_SCHEDULER_INTERVAL_SECONDS=300
ATLAS_INTAKE_SCHEDULER_MAX_DISCOVERY_PER_TICK=5
ATLAS_INTAKE_SCHEDULER_MAX_EMAIL_PER_TICK=3

# --- Find-jobs endpoint ---
ATLAS_FIND_JOBS_THEN_DIGEST=true
ATLAS_FIND_JOBS_DIGEST_FRESH_HOURS=72

# --- Workday ---
ATLAS_WORKDAY_PAGE_PAUSE_SECONDS=0.5

# --- HTTP retry config ---
ATLAS_HTTP_RETRY_MAX_ATTEMPTS=5
ATLAS_HTTP_RETRY_BASE_SECONDS=0.85
ATLAS_HTTP_RETRY_MAX_BACKOFF_SECONDS=60
ATLAS_HTTP_TIMEOUT_CONNECT_SECONDS=12
ATLAS_HTTP_TIMEOUT_READ_SECONDS=50
